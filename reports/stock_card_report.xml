<odoo>

    <template id="stock_card_report.internal_layout">
        <div class="article">
            <link href="/stock_card_report/static/src/css/report.css" rel="stylesheet" />
            <t t-out="0" />
        </div>
        <div class="footer">
            <div class="row">
                <div class="col-6 custom_footer">
                    <span t-out="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')" />
                </div>
                <div class="col-6 text-right custom_footer">
                    Página <span class="page" />/<span class="topage" />
                </div>
            </div>
        </div>
    </template>

    <template id="report_buttons">
        <div class="button_row">
            <button class="o_stock_card_reports_print btn btn-sm oe_button">
                <span class="fa fa-print" /> Imprimir
            </button>
            <button class="o_stock_card_reports_export btn btn-sm oe_button">
                <span class="fa fa-download" /> Exportar
            </button>
        </div>
    </template>

    <template id="report_stock_card_report_html">
        <div class="o_stock_card_reports_page">
            <t t-call="stock_card_report.report_buttons" />
            <t t-call="stock_card_report.report_stock_card_report_base" />
        </div>
    </template>

    <template id="stock_card_report.report_stock_card_report_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="stock_card_report.internal_layout">
                    <t t-call="stock_card_report.report_stock_card_report_base" />
                </t>
            </t>
        </t>
    </template>

    <!-- ================================================================
         TEMPLATE PRINCIPAL
         ================================================================ -->
    <template id="stock_card_report.report_stock_card_report_base">
        <t t-foreach="o.product_ids" t-as="product">
            <div class="page">

                <!-- Cabeçalho do produto -->
                <div class="sc-product-card">
                    <t t-if="product.default_code">
                        <span class="sc-product-ref"><t t-out="product.default_code" /></span>
                    </t>
                    <span class="sc-product-name"><t t-out="product.name" /></span>
                </div>

                <!-- Filtros -->
                <t t-call="stock_card_report.report_stock_card_report_filters" />

                <!-- Tabela de movimentos -->
                <t t-set="initial"         t-value="o._get_product_initial(product)" />
                <t t-set="product_balance" t-value="initial" />
                <t t-set="totals"          t-value="o._get_product_totals(product)" />

                <table class="sc-table">
                    <thead>
                        <tr>
                            <th class="left"  style="width:8%">Data</th>
                            <th class="left"  style="width:12%">Operação</th>
                            <th class="left"  style="width:13%">Referência</th>
                            <th class="left"  style="width:13%">Doc. Origem</th>
                            <th class="left"  style="width:16%">Parceiro</th>
                            <th class="right" style="width:8%">Entradas</th>
                            <th class="right" style="width:8%">Saídas</th>
                            <th class="right" style="width:9%">Preço Unit.</th>
                            <th class="right" style="width:9%">Total</th>
                            <th class="right sc-col-balance" style="width:8%">Saldo</th>
                        </tr>
                    </thead>
                    <tbody>

                        <!-- Saldo Anterior -->
                        <tr class="sc-row-initial">
                            <td colspan="5" class="sc-label left">STOCK ANTERIOR</td>
                            <td class="right">
                                <t t-if="initial > 0">
                                    <t t-out="'{0:,.3f}'.format(initial)" />
                                </t>
                            </td>
                            <td class="right">
                                <t t-if="initial &lt; 0">
                                    <t t-out="'{0:,.3f}'.format(abs(initial))" />
                                </t>
                            </td>
                            <td /><td />
                            <td class="right sc-col-balance">
                                <t t-out="'{0:,.3f}'.format(initial)" />
                            </td>
                        </tr>

                        <!-- Linhas de movimento -->
                        <t t-foreach="o._get_product_lines(product)" t-as="product_line">
                            <t t-set="product_balance"
                               t-value="product_balance + product_line.product_in - product_line.product_out" />
                            <tr class="sc-row-move">
                                <td class="left">
                                    <t t-out="product_line.date.strftime('%d/%m/%Y')" />
                                </td>
                                <td class="left">
                                    <t t-out="product_line.picking_type_name or ''" />
                                </td>
                                <td class="left">
                                    <t t-out="product_line.display_name or ''" />
                                </td>
                                <td class="left">
                                    <t t-out="product_line.picking_origin or ''" />
                                </td>
                                <td class="left">
                                    <t t-out="product_line.partner_name or ''" />
                                </td>
                                <td class="right">
                                    <t t-if="product_line.product_in">
                                        <t t-out="'{0:,.3f}'.format(product_line.product_in)" />
                                    </t>
                                    <t t-else=""><span class="sc-zero">—</span></t>
                                </td>
                                <td class="right">
                                    <t t-if="product_line.product_out">
                                        <t t-out="'{0:,.3f}'.format(product_line.product_out)" />
                                    </t>
                                    <t t-else=""><span class="sc-zero">—</span></t>
                                </td>
                                <td class="right">
                                    <t t-if="product_line.price_unit">
                                        <t t-out="'{0:,.2f}'.format(product_line.price_unit)" />
                                    </t>
                                    <t t-else=""><span class="sc-zero">—</span></t>
                                </td>
                                <td class="right">
                                    <t t-if="product_line.price_total">
                                        <t t-out="'{0:,.2f}'.format(product_line.price_total)" />
                                    </t>
                                    <t t-else=""><span class="sc-zero">—</span></t>
                                </td>
                                <td class="right sc-col-balance">
                                    <t t-out="'{0:,.3f}'.format(product_balance)" />
                                </td>
                            </tr>
                        </t>

                        <!-- Linha de TOTAIS -->
                        <tr class="sc-row-totals">
                            <td colspan="5" class="sc-label left">TOTAIS</td>
                            <td class="right"><t t-out="'{0:,.3f}'.format(totals['total_in'])" /></td>
                            <td class="right"><t t-out="'{0:,.3f}'.format(totals['total_out'])" /></td>
                            <td /><td />
                            <td class="right sc-col-balance">
                                <t t-out="'{0:,.3f}'.format(totals['final_balance'])" />
                            </td>
                        </tr>

                    </tbody>
                </table>

                <p style="page-break-before:always;" />
            </div>
        </t>
    </template>

    <!-- Filtros em bloco horizontal -->
    <template id="stock_card_report.report_stock_card_report_filters">
        <div class="sc-filters">
            <div class="sc-filter-item">
                <span class="sc-filter-label">Data Inicial</span>
                <span class="sc-filter-value"><span t-field="o.date_from" /></span>
            </div>
            <div class="sc-filter-item">
                <span class="sc-filter-label">Data Final</span>
                <span class="sc-filter-value"><span t-field="o.date_to" /></span>
            </div>
            <div class="sc-filter-item">
                <span class="sc-filter-label">Localização</span>
                <span class="sc-filter-value"><span t-field="o.location_id" /></span>
            </div>
        </div>
    </template>

    <!-- Mantidos por compatibilidade com herança externa -->
    <template id="stock_card_report.report_stock_card_lines_header" />
    <template id="stock_card_report.report_stock_card_lines" />

</odoo>
